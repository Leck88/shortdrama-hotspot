    "pipeline": "SDXL文生图(1024x1820) → ImageScale(1080x1920保存) → ImageScale(832x480) → Wan2.2 I2V(8秒视频)",
    "resolution": "SDXL输出1080x1920，I2V输入832x480",
    "output": "8秒MP4视频 (8fps, 64帧) + 1080x1920分镜图",
    "nodes": {
      "CheckpointLoaderSimple": "ComfyUI内置节点，加载SDXL模型",
      "CLIPTextEncode": "ComfyUI内置节点，编码正/反向提示词（SDXL和I2V各一组）",
      "EmptySDXLLatentImage": "ComfyUI内置节点，生成SDXL空Latent",
      "KSampler": "ComfyUI内置节点，K采样器（SDXL用euler_ancestral，I2V用uni_pc_bh2）",
      "VAEDecode": "ComfyUI内置节点，VAE解码",
      "ImageScale": "ComfyUI内置节点，缩放图片（1080x1920保存+832x480输入I2V）",
      "SaveImage": "ComfyUI内置节点，保存分镜图",
      "UNETLoader": "ComfyUI内置节点，加载Wan2.2 I2V UNet",
      "CLIPLoader": "ComfyUI内置节点，加载Wan2.2 CLIP",
      "VAELoader": "ComfyUI内置节点，加载Wan2.2 VAE",
      "WanImageToVideo": "ComfyUI-Wan2.2自定义节点，I2V核心节点",
      "VHS_VideoCombine": "ComfyUI-VideoHelperSuite自定义节点，合成MP4视频"
    },
    "model_requirements": {
      "sdxl_checkpoint": "sd_xl_base_1.0.safetensors (ComfyUI models/checkpoints/目录)",
      "wan22_unet": "wan2.2_i2v_14b_480p (fp8量化推荐，ComfyUI models/diffusion_models/目录)",
      "wan22_clip": "clip_vision_h (ComfyUI models/clip/目录，类型选wan2.1)",
      "wan22_vae": "wan2.2_vae (ComfyUI models/vae/目录)",
      "custom_nodes": [
        "ComfyUI-Wan2.2 (提供WanImageToVideo节点)",
        "ComfyUI-VideoHelperSuite (提供VHS_VideoCombine节点)"
      ]
    },
    "template_variables": {
      "{{POSITIVE_PROMPT}}": "SDXL正向提示词，描述分镜画面",
      "{{MOTION_PROMPT}}": "Wan2.2运动提示词，描述视频中的运动",
      "{SCENE_ID}": "场次编号，如 001、002"
