  "_readme": {
    "title": "Wan2.2 I2V 480P 8秒视频生成",
    "usage": "替换{{MOTION_PROMPT}}为运动描述，{SCENE_ID}为场次编号",
    "input_image": "SDXL生成的1080x1920分镜图，自动resize到832x480输入Wan2.2",
    "output": "8秒MP4视频 (8fps, 64帧)",
    "nodes": {
      "UNETLoader": "ComfyUI内置节点，加载Wan2.2 I2V扩散模型(UNet部分)",
      "CLIPLoader": "ComfyUI内置节点，加载CLIP文本编码器(wan2.1类型)",
      "VAELoader": "ComfyUI内置节点，加载Wan2.2 VAE",
      "LoadImage": "ComfyUI内置节点，加载SDXL生成的分镜图",
      "ImageScale": "ComfyUI内置节点，缩放到Wan2.2输入尺寸832x480",
      "CLIPTextEncode": "ComfyUI内置节点，编码运动提示词和反向提示词",
      "WanImageToVideo": "ComfyUI-Wan2.2自定义节点，I2V核心节点，接收model/positive/negative/vae/image输入，输出positive/negative/latent",
      "KSampler": "ComfyUI内置节点，I2V采样(uni_pc_bh2采样器)",
      "VAEDecode": "ComfyUI内置节点，VAE解码latent到视频帧",
      "VHS_VideoCombine": "ComfyUI-VideoHelperSuite自定义节点，将帧合成为MP4视频"
    },
    "model_requirements": {
      "unet": "wan2.2_i2v_14b_480p (fp8量化推荐，需在ComfyUI models/diffusion_models/目录)",
      "clip": "clip_vision_h (需在ComfyUI models/clip/目录，类型选wan2.1)",
      "vae": "wan2.2_vae (需在ComfyUI models/vae/目录)",
      "custom_nodes": [
        "ComfyUI-Wan2.2 (提供WanImageToVideo节点)",
        "ComfyUI-VideoHelperSuite (提供VHS_VideoCombine节点)"
      ]
    },
    "time_4080S": "约3-5分钟/视频",
    "note": "Wan2.2 I2V-14B模型在480P分辨率下生成，输出后可upscale到1080P"
  }
}